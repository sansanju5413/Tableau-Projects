          <datasource-dependencies datasource='federated.1i0e0lf099go5p13f5gc2139r0yn'>
            <column caption='Key Insights' datatype='string' name='[Calculation_1220196638224401]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='&quot;• August recorded the highest number of bookings (2,604).&#13;&#10;&#13;&#10;• Portugal (PRT) generated the highest number of bookings with 9,282 reservations.&#13;&#10;&#13;&#10;• The overall cancellation rate was 44.84%, indicating a significant proportion of bookings were cancelled.&#13;&#10;&#13;&#10;• BB meal plan was the most preferred option, accounting for 13,983 bookings.&#13;&#10;&#13;&#10;• Confirmed bookings (9,767) exceeded cancelled bookings (7,940).&quot;' />
            </column>
            <column caption='Country' datatype='string' name='[country]' role='dimension' semantic-role='[Country].[ISO3166_2]' type='nominal' />
            <column-instance column='[Calculation_1220196638224401]' derivation='None' name='[none:Calculation_1220196638224401:nk]' pivot='key' type='nominal' />
          </datasource-dependencies>
          <filter class='categorical' column='[federated.1i0e0lf099go5p13f5gc2139r0yn].[Action (Country)]'>
            <groupfilter function='level-members' level='[country]' user:ui-action-filter='[Action1_B83F398BA7974B8E8119807C3687AD6A]' user:ui-enumeration='all' user:ui-marker='enumerate' />
